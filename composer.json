{
    "name": "jiri/ai-provider-for-nanogpt",
    "description": "nano-gpt.com AI provider for the PHP AI Client SDK. Works as both a Composer package and WordPress plugin.",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "ai",
        "nanogpt",
        "nano-gpt",
        "wordpress",
        "llm",
        "image-generation"
    ],
    "authors": [
        {
            "name": "Jiri"
        }
    ],
    "homepage": "https://nano-gpt.com/",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wordpress/php-ai-client": "^0.4 || dev-trunk"
    },
    "suggest": {
        "wordpress/php-ai-client": "Required. The core PHP AI Client SDK that this provider extends."
    },
    "autoload": {
        "psr-4": {
            "WordPress\\NanoGptAiProvider\\": "src/"
        },
        "files": [
            "src/polyfill.php"
        ]
    },
    "config": {
        "platform": {
            "php": "7.4"
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "parallel-lint --colors --exclude vendor .",
        "stan": "phpstan analyse --memory-limit=512M"
    }
}
